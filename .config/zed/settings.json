// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_install_extensions": {
    "catppuccin": true,
    "symbols": true,
    "codebook": true,
    "dockerfile": true,
    "docker-compose": true,
    "emmet": true,
    "git-firefly": true,
    "graphql": true,
    "html": true,
    "prisma": true,
    "sql": true,
  },
  "disable_ai": true,
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "icon_theme": {
    "mode": "light",
    "light": "Symbols Icon Theme",
    "dark": "Symbols Icon Theme"
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "experimental.theme_overrides": {
    "syntax": {
      "keyword": { "font_style": "italic" },
      // "keyword.control": { "font_style": "italic" },
      // "attribute": { "font_style": "italic" },
      // "type": { "font_style": "italic" },
      // "comment": { "font_style": "italic" },
      // "comment.doc": { "font_style": "italic" },
      // "function": { "font_style": "italic" },
      // "string": { "font_style": "italic" },
      // "variable": { "font_style": "italic" },
      // "property": { "font_style": "italic" },
      // "operator": { "font_style": "italic" },
      // "punctuation": { "font_style": "italic" },
    },
  },
  "ui_font_family": "VictorMono Nerd Font Mono",
  "ui_font_size": 15,
  "ui_font_weight": 500,
  "buffer_font_family": "VictorMono Nerd Font Mono",
  "buffer_font_size": 12,
  "buffer_font_weight": 500,
  "agent_ui_font_size": 15,
  "agent_buffer_font_size": 12,
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 380,
    "hide_root": false,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "always",
    },
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "scrollbar": {
    "git_diff": false,
    "show": "always",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
    "breakpoints": false,
    "bookmarks": false,
  },
  "indent_guides": {
    "enabled": true,
  },
  "multi_cursor_modifier": "alt",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "selection_highlight": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": "preserve_indent",
  "auto_indent_on_paste": true,
  "show_completions_on_input": true,
  "show_completion_documentation": false,
  "inline_code_actions": false,
  "lsp_document_colors": "inlay",
  "colorize_brackets": true,
  "hover_popover_enabled": true,
  "format_on_save": "on",
  "auto_update": false,
  "extend_comment_on_newline": false,
  "soft_wrap": "editor_width",
  "mouse_wheel_zoom": true,
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
}

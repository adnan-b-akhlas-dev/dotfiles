// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "auto_install_extensions": {
    "catppuccin": true,
    "symbols": true,
    "codebook": true,
    "dockerfile": true,
    "docker-compose": true,
    "emmet": true,
    "git-firefly": true,
    "graphql": true,
    "html": true,
    "prisma": true,
    "sql": true,
  },
  "disable_ai": true,
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "icon_theme": "Symbols Icon Theme",
  "theme": "Catppuccin Mocha",
  "ui_font_family": "VictorMono Nerd Font Mono",
  "ui_font_size": 16,
  "buffer_font_family": "VictorMono Nerd Font Mono",
  "buffer_font_size": 14,
  "buffer_line_height": {
    "custom": 1.8,
  },
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 14,
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": false,
    "show_sign_in": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 350,
    "hide_root": false,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "always",
    },
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "scrollbar": {
    "show": "auto",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
    "breakpoints": false,
    "bookmarks": false,
  },
  "indent_guides": {
    "enabled": true,
  },
  "multi_cursor_modifier": "alt",
  "cursor_shape": "bar",
  "cursor_blink": true,
  "selection_highlight": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": "preserve_indent",
  "auto_indent_on_paste": true,
  "show_completions_on_input": true,
  "show_completion_documentation": false,
  "inline_code_actions": false,
  "lsp_document_colors": "inlay",
  "colorize_brackets": true,
  "hover_popover_enabled": true,
  "format_on_save": "on",
  "auto_update": false,
  "extend_comment_on_newline": false,
  "soft_wrap": "editor_width",
  "mouse_wheel_zoom": true,
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false,
    },
  },
}

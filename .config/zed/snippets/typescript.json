{
  "Console Log": {
    "prefix": "log",
    "body": ["console.log($0)"],
    "description": "Log to the console"
  },
  "Console Warn": {
    "prefix": "warn",
    "body": ["console.warn($0)"],
    "description": "Warning log to the console"
  },
  "Console Error": {
    "prefix": "error",
    "body": ["console.error($0)"],
    "description": "Error log to the console"
  },
  "Console Table": {
    "prefix": "table",
    "body": ["console.table($0)"],
    "description": "Display data as a table in the console"
  },
  "Console Time": {
    "prefix": "time",
    "body": [
      "console.time('${1:label}');",
      "$0",
      "console.timeEnd('${1:label}');"
    ],
    "description": "Measure execution time"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "function ${1:functionName}(${2:params}): ${3:void} {",
      "\t$0",
      "}"
    ],
    "description": "Standard function declaration"
  },
  "Arrow Function": {
    "prefix": "af",
    "body": ["const ${1:functionName} = (${2:params}): ${3:void} => {$0}"],
    "description": "Arrow function assignment"
  },
  "Arrow Function Implicit Return": {
    "prefix": "afe",
    "body": ["const ${1:functionName} = (${2:params}): ${3:ReturnType} => $0"],
    "description": "One-line arrow function with implicit return"
  },
  "Async Function": {
    "prefix": "asf",
    "body": [
      "async function ${1:functionName}(${2:params}): Promise<${3:void}> {",
      "\t$0",
      "}"
    ],
    "description": "Async function declaration"
  },
  "Async Arrow Function": {
    "prefix": "asa",
    "body": [
      "const ${1:functionName} = async (${2:params}): Promise<${3:void}> => {$0}"
    ],
    "description": "Async arrow function assignment"
  },
  "Anonymous Function": {
    "prefix": "afn",
    "body": ["(${1:params}): ${2:void} => {", "\t$0", "}"],
    "description": "Anonymous arrow function"
  },
  "Anonymous Arrow Function": {
    "prefix": "aaf",
    "body": ["(${1:params}) => {", "\t$0", "}"],

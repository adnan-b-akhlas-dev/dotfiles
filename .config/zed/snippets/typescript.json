  },
  "Async Anonymous Function": {
    "prefix": "asafn",
    "body": ["async (${1:params}): Promise<${2:void}> => {", "\t$0", "}"],
    "description": "Async anonymous arrow function with Promise return type"
  },
  "Async Anonymous Arrow Function": {
    "prefix": "asaaf",
    "body": ["async (${1:params}) => {", "\t$0", "}"],
    "description": "Async anonymous arrow function without explicit return type"
  },
  "IIFE": {
    "prefix": "iife",
    "body": ["(function(${1:params}): ${2:void} {", "\t$0", "})();"],
    "description": "Immediately Invoked Function Expression"
  },
  "Async IIFE": {
    "prefix": "aiife",
    "body": [
      "(async function(${1:params}): Promise<${2:void}> {",
      "\t$0",
      "})();"
    ],
    "description": "Async Immediately Invoked Function Expression"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:i} = 0; ${1:i} < ${2:array}.length; ${1:i}++) {",

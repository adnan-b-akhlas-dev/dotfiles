// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-j": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-j": "workspace::ToggleBottomDock",
    },
  },
  {
    "bindings": {
      "ctrl-alt-y": "workspace::ToggleAllDocks",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "j": ["workspace::SendKeystrokes", "g j"],
      "k": ["workspace::SendKeystrokes", "g k"],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-k": "editor::DuplicateLineUp",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-up": "editor::DuplicateLineUp",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-j": "editor::DuplicateLineDown",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-down": "editor::DuplicateLineDown",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-up": "editor::MoveLineUp",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-j": "editor::MoveLineDown",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-down": "editor::MoveLineDown",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-shift-y": "workspace::ToggleAllDocks",
    },
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-shift-enter": "editor::NewlineAbove",
    },
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-enter": "editor::NewlineBelow",
    },
  },
]
